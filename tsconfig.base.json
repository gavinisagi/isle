{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Modern target; each package overrides module/lib as needed / 现代目标,各包按需覆盖 module/lib
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],

    // Strictness — the project's type-safety floor / 严格性:项目类型安全底线
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    // Interop / 互操作
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // Map the protocol package so host/mock import it by name pre-build / 让 host/mock 构建前即可按包名引用协议
    "paths": {
      "@isle/protocol": ["./packages/protocol/src/index.ts"]
    }
  }
}
