# Copy to .env (gitignored) and fill your own paths. / 复制为 .env(已 gitignore)并填你自己的路径
# Absolute path to your holdings JSON: { holdings: [{ code, name, type, quantity, cost }] }. / 你的持仓 JSON 绝对路径
ISLE_CFG_HOLDINGSPATH=C:\path\to\Obsidian Vault\我的\持仓.json
# Refresh interval in ms — 60000 = 1 min. / 刷新间隔(ms),60000 = 1 分钟
ISLE_CFG_REFRESHMS=60000
